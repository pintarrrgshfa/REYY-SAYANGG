  <script>
    const slider = document.getElementById('slider');
    const slides = document.querySelectorAll('.slide');
    const thumbs = document.querySelectorAll('.thumb');
    const counterText = document.getElementById('counterText');
    const progressBar = document.getElementById('progressBar');
    const totalSlides = slides.length;
    let currentIndex = 0;

    function updateSlider(index) {
      currentIndex = (index + totalSlides) % totalSlides;
      slider.style.transform = `translateX(-${currentIndex * 100}%)`;
      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle('active', i === currentIndex);
      });
      counterText.textContent = `Foto ${currentIndex + 1} dari ${totalSlides}`;
      progressBar.style.width = `${((currentIndex + 1) / totalSlides) * 100}%`;
    }

    document.getElementById('prevBtn').addEventListener('click', () => updateSlider(currentIndex - 1));
    document.getElementById('nextBtn').addEventListener('click', () => updateSlider(currentIndex + 1));

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener('click', () => updateSlider(index));
    });

    let startX = 0;
    let endX = 0;
    const sliderWrap = document.getElementById('sliderWrap');

    sliderWrap.addEventListener('touchstart', (e) => {
      startX = e.changedTouches[0].clientX;
    }, { passive: true });

    sliderWrap.addEventListener('touchend', (e) => {
      endX = e.changedTouches[0].clientX;
      const distance = endX - startX;
      if (Math.abs(distance) > 45) {
        if (distance < 0) {
          updateSlider(currentIndex + 1);
        } else {
          updateSlider(currentIndex - 1);
        }
      }
    }, { passive: true });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') updateSlider(currentIndex + 1);
      if (e.key === 'ArrowLeft') updateSlider(currentIndex - 1);
    });

    updateSlider(0);
  </script>
